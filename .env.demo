# ── DocuBot — Variables de entorno para demo local ──────────────────────────
# Copia este archivo a .env y ajusta según tu entorno real.
# En modo DEMO, las llamadas a Azure OpenAI retornan respuestas simuladas.

ENVIRONMENT=demo
DEBUG=true

# Base de datos (configurada por docker-compose)
DATABASE_URL=postgresql+asyncpg://docubot:docubot_dev_2025@db:5432/docubot

# Azure OpenAI — dejar vacío en demo, el mock los ignora
AZURE_OPENAI_API_KEY=demo-key
AZURE_OPENAI_ENDPOINT=https://demo.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_EMBEDDINGS=text-embedding-3-large
GPT_TIMEOUT_SECONDS=30

# Azure Blob Storage — en demo usa almacenamiento local
AZURE_BLOB_CONNECTION_STRING=demo
AZURE_BLOB_CONTAINER_NAME=documents

# Azure Document Intelligence — en demo usa extracción de texto simple
AZURE_DOCUMENT_INTELLIGENCE_KEY=demo-key
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://demo.cognitiveservices.azure.com/

# Azure Service Bus — en demo procesa sincrónicamente
AZURE_SERVICE_BUS_CONNECTION_STRING=demo
AZURE_SERVICE_BUS_QUEUE_INGESTION=document-processing
AZURE_SERVICE_BUS_QUEUE_ALERTS=alert-notifications

# Azure AD B2C — en demo acepta cualquier token o usuario hardcoded
AZURE_AD_B2C_TENANT=demo
AZURE_AD_B2C_CLIENT_ID=demo-client-id
AZURE_AD_B2C_POLICY=B2C_1_signupsignin
AZURE_AD_B2C_AUTHORITY=https://login.microsoftonline.com/demo

# CORS — frontend local
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# JWT Secret para demo (no usar en producción)
JWT_SECRET_KEY=docubot-demo-secret-key-2025-not-for-production

# Configuración de la app
MAX_UPLOAD_SIZE_MB=50
DEFAULT_TOP_K=8
