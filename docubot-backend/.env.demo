# DocuBot Backend — Modo demo local (sin OpenAI, sin DB real)
ENVIRONMENT=development
DEBUG=true
DATABASE_URL=postgresql+asyncpg://docubot:docubot@localhost:5432/docubot_demo
OPENAI_API_KEY=demo-key-not-used
OPENAI_MODEL_GPT4O=gpt-4o
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
STORAGE_LOCAL_PATH=/tmp/docubot_uploads
JWT_SECRET_KEY=demo-secret-key-insecure
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
MAX_FILE_SIZE_MB=50
MAX_PAGES_PER_DOCUMENT=1000
RAG_DEFAULT_TOP_K=8
RAG_MAX_TOP_K=20
OCR_TIMEOUT_SECONDS=60
