# ══════════════════════════════════════════════════════════════════════
# DocuBot Backend — Variables de entorno
# Copia este archivo a .env y completa cada valor antes del primer deploy.
# NUNCA subas el archivo .env real al repositorio.
# ══════════════════════════════════════════════════════════════════════

# ── Entorno ───────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Base de datos — Railway PostgreSQL ───────────────────────────────
# Railway lo genera automáticamente al añadir el plugin PostgreSQL.
# Formato: postgresql+asyncpg://<user>:<password>@<host>:5432/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:<PASSWORD>@<host>.railway.app:5432/railway

# ── OpenAI ────────────────────────────────────────────────────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL_GPT4O=gpt-4o
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
GPT_TIMEOUT_SECONDS=60

# ── Almacenamiento local ──────────────────────────────────────────────
# En Railway: crear un volumen persistente montado en /data
# En desarrollo local: cualquier directorio local
STORAGE_LOCAL_PATH=/data/documents

# ── Auth JWT ──────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<genera-un-token-aleatorio-de-64-chars>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── CORS — Orígenes permitidos ────────────────────────────────────────
# Incluir la URL del frontend en Netlify y el dominio personalizado si aplica
ALLOWED_ORIGINS=["https://aurenza-group.netlify.app","https://docubot.aurenzagroup.cl","http://localhost:5173"]

# ── Límites operacionales ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
MAX_PAGES_PER_DOCUMENT=1000
RAG_DEFAULT_TOP_K=8
RAG_MAX_TOP_K=20
OCR_TIMEOUT_SECONDS=60
