# DocuBot Frontend — Variables de entorno
# Copiar a .env.local para desarrollo, o configurar en Azure Static Web Apps

# ─── API Backend ──────────────────────────────────────────────
# URL base del backend FastAPI (sin trailing slash)
VITE_API_BASE_URL=https://docubot-api.azurecontainerapps.io

# ─── Modo demo (salta auth B2C, usa datos simulados) ──────────
VITE_DEMO_MODE=false
VITE_DEMO_PROJECT_ID=

# ─── Azure AD B2C ─────────────────────────────────────────────
# Client ID de la aplicación registrada en Azure AD B2C
VITE_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Authority URL del tenant B2C con policy de sign-in
# Formato: https://<tenant>.b2clogin.com/<tenant>.onmicrosoft.com/<policy>
VITE_AZURE_AUTHORITY=https://aurenzab2c.b2clogin.com/aurenzab2c.onmicrosoft.com/B2C_1_signin

# URI de redirección registrado en la app B2C
VITE_AZURE_REDIRECT_URI=https://docubot.aurenza.com

# Tenant ID (para silent token renewal)
VITE_DEMO_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
